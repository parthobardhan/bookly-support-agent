# Copy to .env and fill in values.

# MongoDB Atlas SRV connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Database name (default: bookly)
MONGODB_DB_NAME=bookly

# Atlas Vector Search index name on the policies collection (default: bookly_policy_vector_index)
MONGODB_VECTOR_INDEX_NAME=bookly_policy_vector_index

# API keys
OPENAI_API_KEY=
VOYAGE_API_KEY=
DEEPGRAM_API_KEY=

# Optional overrides
OPENAI_MODEL=gpt-4o
VOYAGE_EMBED_MODEL=voyage-4
VOYAGE_EMBED_DIMENSIONS=1024
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Flux streaming STT (voice mode WebRTC)
DEEPGRAM_FLUX_MODEL=flux-general-en
FLUX_EOT_THRESHOLD=0.7
FLUX_EOT_TIMEOUT_MS=5000
# FLUX_EAGER_EOT_THRESHOLD=0.5

# Streaming TTS sample rate for Speak WebSocket (Hz)
DEEPGRAM_SPEAK_SAMPLE_RATE=24000
